APP_ENV=development
APP_NAME=EvalLedger
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://evalledger:evalledger@localhost:5432/evalledger
SYNC_DATABASE_URL=postgresql+psycopg://evalledger:evalledger@localhost:5432/evalledger
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
JWT_SECRET_KEY=change-me
CORS_ORIGINS=["http://localhost:3000"]
ADMIN_EMAILS=["admin@example.com"]

# OAuth — GitHub (https://github.com/settings/developers → OAuth Apps)
# Callback URL: http://localhost:8000/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# Callback URL: http://localhost:8000/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Storage — set STORAGE_BACKEND=local for development (default).
# For production durable storage use STORAGE_BACKEND=s3 with Cloudflare R2.
# See docs/operations/deployment.md → "Durable artifact storage (Cloudflare R2)"
STORAGE_BACKEND=local
STORAGE_ROOT=storage
STORAGE_BUCKET=evalledger-artifacts
MAX_PUBLIC_UPLOAD_BYTES=10485760
MAX_AUTHENTICATED_UPLOAD_BYTES=262144000
ALLOWED_ARTIFACT_EXTENSIONS=[".json",".jsonl",".csv",".parquet"]

# S3-compatible storage credentials (only required when STORAGE_BACKEND=s3)
# Cloudflare R2 example values shown — replace with your actual R2 details.
# STORAGE_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_S3_ACCESS_KEY_ID=<r2-access-key-id>
# STORAGE_S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
# STORAGE_S3_REGION=auto
# STORAGE_S3_PRESIGN_ENDPOINT=https://pub-<hash>.r2.dev
# STORAGE_S3_PRESIGN_TTL=3600
