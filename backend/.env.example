APP_ENV=development
APP_NAME=EvalLedger
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://evalledger:evalledger@localhost:5432/evalledger
SYNC_DATABASE_URL=postgresql+psycopg://evalledger:evalledger@localhost:5432/evalledger
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
JWT_SECRET_KEY=change-me
CORS_ORIGINS=["http://localhost:3000"]
ADMIN_EMAILS=["admin@example.com"]

# OAuth — GitHub (https://github.com/settings/developers → OAuth Apps)
# Callback URL: http://localhost:8000/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# Callback URL: http://localhost:8000/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STORAGE_BACKEND=local
STORAGE_ROOT=storage
STORAGE_BUCKET=evalledger-artifacts
MAX_PUBLIC_UPLOAD_BYTES=10485760
MAX_AUTHENTICATED_UPLOAD_BYTES=262144000
ALLOWED_ARTIFACT_EXTENSIONS=[".json",".jsonl",".csv",".parquet"]
