# Public API URL – used by the browser (Next.js client components).
# In production, set this to the Fly.io API URL in your Vercel project settings.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API URL – used by Next.js server-side rendering / API routes.
# Same as NEXT_PUBLIC_API_URL for Vercel deployments (no internal network path).
API_INTERNAL_URL=http://localhost:8000
